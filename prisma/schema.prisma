generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone String? @unique
  password  String
  role      String   @default("customer")
  createdAt DateTime @default(now())
}

model Feedback {
  id           Int      @id @default(autoincrement())
  customerName String
  email        String
  category     String
  feedback     String
  sentiment    String   @default("Neutral")
  rating Int @default(5)
  createdAt    DateTime @default(now())
}